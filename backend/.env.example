# Copy to: .env.development | .env.test | .env.production (never commit those files)
# Convention: API_* public server, DB_* database, REDIS_* cache (REDIS_URI after alias)

NODE_ENV=development

# Escuta em todas as interfaces (acesso na LAN)
LISTEN_HOST=0.0.0.0

# API — listening port (alias: PORT)
API_PORT=8080

# Public URLs (required)
API_PUBLIC_URL=http://localhost:8080
API_FRONTEND_URL=http://localhost:2303

# Legacy names still supported: BACKEND_URL, FRONTEND_URL
# BACKEND_URL=http://localhost:8080
# FRONTEND_URL=http://localhost:2303

# Database
DB_DIALECT=postgres
DB_HOST=127.0.0.1
DB_PORT=5432
DB_USER=ticketz
DB_PASS=
DB_NAME=ticketz
# DB_TIMEZONE=-03:00
# DB_DEBUG=

# Redis (REDIS_URL is copied to REDIS_URI if REDIS_URI is unset)
REDIS_URL=redis://127.0.0.1:6379
# REDIS_URI=redis://127.0.0.1:6379
REDIS_OPT_LIMITER_MAX=1
REDIS_OPT_LIMITER_DURATION=3000

# Optional auth overrides (otherwise secrets are generated/stored in Redis)
# AUTH_JWT_SECRET=
# AUTH_JWT_REFRESH_SECRET=

# Optional
LOG_LEVEL=debug
# SENTRY_DSN=
# ENV_TOKEN=
# EMAIL_ADDRESS=admin@ticketz.host
# TICKETZ_REGISTRY_URL=
# RECAPTCHA_SECRET_KEY=

USER_LIMIT=10000
CONNECTIONS_LIMIT=100000
CLOSED_SEND_BY_ME=true

# Desenvolvimento na rede: permitir qualquer host na porta do front (só dev)
# FRONTEND_URL_REGEX=^http://.*:2303$
