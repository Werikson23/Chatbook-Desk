# Copy to .env.development (local) or .env.production (build server)
# CRA exposes only variables prefixed with REACT_APP_

# Full backend base URL (optional — overrides public/config.json when set)
REACT_APP_BACKEND_URL=http://localhost:8080

# Optional: socket URL if different from HTTP origin (rare)
# REACT_APP_BACKEND_SOCKET_URL=http://localhost:8080

# Optional: URL do webhook n8n (ou outro) para formulário Pix Ticketz em Configurações
# REACT_APP_PIX_TICKETZ_WEBHOOK_URL=
